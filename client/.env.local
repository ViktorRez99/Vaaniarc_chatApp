# Local development environment
# Leave VITE_API_URL empty to use the Vite proxy (recommended for local dev)
# The proxy is configured in vite.config.js to forward /api requests to localhost:3000

# Uncomment below if you want to bypass the proxy and connect directly
# VITE_API_URL=http://127.0.0.1:3000
# VITE_SOCKET_URL=http://127.0.0.1:3000
