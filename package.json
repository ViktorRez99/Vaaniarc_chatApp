{
  "name": "realtime-chat-app",
  "version": "1.0.0",
  "description": "A real-time chat application using WebSocket technology",
  "main": "server/entry.js",
  "scripts": {
    "start": "node server/entry.js",
    "dev": "nodemon server/entry.js",
    "client": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "build": "npm run client:build",
    "setup": "npm install && cd client && npm install && cd ..",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "vercel-build": "npm run build",
    "postinstall": "cd client && npm install",
    "test": "jest && npm --prefix client run test",
    "testsprite": "node -e \"console.log('TestSprite runs via Cursor MCP. See TESTSPRITE.md in repo root.')\""
  },
  "keywords": [
    "chat",
    "websocket",
    "realtime",
    "socket.io",
    "express"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@sentry/node": "^7.88.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.7.13",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.1",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  }
}
