# =================================
# SERVER CONFIGURATION
# =================================
PORT=3000
NODE_ENV=development

# =================================
# DATABASE CONFIGURATION
# =================================
# Local MongoDB (Development)
# MONGODB_URI=mongodb://localhost:27017/chatapp

# MongoDB Atlas (Production - Recommended)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp?retryWrites=true&w=majority

# =================================
# JWT AUTHENTICATION
# =================================
# IMPORTANT: Change this to a strong, random secret in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# =================================
# FILE UPLOAD CONFIGURATION
# =================================
# Maximum file size in bytes (10MB = 10485760 bytes)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,video/mp4,video/webm,audio/mp3,audio/mpeg,text/plain,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/octet-stream

# =================================
# CORS CONFIGURATION
# =================================
# Frontend URL (Update with your production domain)
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173
# Optional comma-separated allowlist for exact frontend origins
# Example: ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=

# =================================
# SESSION / COOKIE AUTH
# =================================
# Session duration in milliseconds (default 7 days)
SESSION_DURATION_MS=604800000
# Use strict for same-site deployments, none for separate frontend/backend origins over HTTPS
SESSION_COOKIE_SAMESITE=strict

# =================================
# REDIS / CACHE
# =================================
# Optional in development, recommended for Railway parity and presence fan-out
# REDIS_URL=redis://127.0.0.1:6379

# =================================
# PASSKEY / WEBAUTHN
# =================================
WEBAUTHN_RP_NAME=VaaniArc
# Set false only for a controlled migration window; true enforces passkey setup after sign-in.
PASSKEYS_REQUIRED=true
# Leave unset in development to derive from the incoming origin.
# WEBAUTHN_RP_ID=localhost
# Optional comma-separated allowlist of exact browser origins that can create or use passkeys
# WEBAUTHN_ORIGINS=http://localhost:5173,https://app.example.com

# =================================
# WEB PUSH NOTIFICATIONS
# =================================
# Generate with:
# npx web-push generate-vapid-keys
WEB_PUSH_SUBJECT=https://example.com
WEB_PUSH_VAPID_PUBLIC_KEY=replace_with_generated_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=replace_with_generated_private_key
# Vite client reads the same public key through /api/notifications/config.

# =================================
# RATE LIMITING
# =================================
# Time window in milliseconds (15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per window
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# OPTIONAL: LOGGING
# =================================
# LOG_LEVEL=info
# LOG_FILE=logs/app.log
