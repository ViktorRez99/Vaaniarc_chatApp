le={msg.self\n                                    ? { background: `${chat.user.color}0D`, border: `1px solid ${chat.user.color}22` }\n                                    : { background: 'rgba(255,255,255,0.03)', border: '1px solid var(--border-subtle)' }}>\n                                  <p className=\"text-[11px] leading-relaxed\" style={{ color: msg.self ? 'var(--text-primary)' : 'var(--text-secondary)' }}>{msg.text}</p>\n                                  <p className=\"text-[8px] mt-1 font-mono\" style={{ color: 'var(--text-muted)' }}>{msg.time}</p>\n                                </div>\n                              </motion.div>\n                            ))}\n                          </motion.div>\n                        </AnimatePresence>\n                      </>\n                    )\n                  })", "source_file": "C:\\Users\\abhra\\OneDrive\\Documents\\vaaniArc\\client\\src\\components\\LandingPage.jsx", "source_location": "L348"}, {"caller_nid": "landingpage_landingpage", "callee": "map", "source_file": "C:\\Users\\abhra\\OneDrive\\Documents\\vaaniArc\\client\\src\\components\\LandingPage.jsx", "source_location": "L408"}, {"caller_nid": "landingpage_landingpage", "callee": "map", "source_file": "C:\\Users\\abhra\\OneDrive\\Documents\\vaaniArc\\client\\src\\components\\LandingPage.jsx", "source_location": "L431"}, {"caller_nid": "landingpage_landingpage", "callee": "(() => { const Icon = landingFeatures[activeFeature].icon; return <Icon className=\"w-10 h-10\" style={{ color: landingFeatures[activeFeature].color }} /> })", "source_file": "C:\\Users\\abhra\\OneDrive\\Documents\\vaaniArc\\client\\src\\components\\LandingPage.jsx", "source_location": "L459"}, {"caller_nid": "landingpage_landingpage", "callee": "map", "source_file": "C:\\Users\\abhra\\OneDrive\\Documents\\vaaniArc\\client\\src\\components\\LandingPage.jsx", "source_location": "L486"}, {"caller_nid": "landingpage_landingpage", "callee": "map", "source_file": "C:\\Users\\abhra